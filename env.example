AUTH_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="your-secure-password"

# Shared Postgres instance is fine — portfolio tables live in the "portfolio" schema
# and will not touch tables in the default "public" schema.
POSTGRES_URL="postgres://...@db.prisma.io:5432/postgres?sslmode=require"

BLOB_STORE_ID="..."
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# CONTACT_FROM_EMAIL must be a verified sender in Resend (use onboarding@resend.dev for sandbox testing).
RESEND_API_KEY="re_..."
CONTACT_TO_EMAIL="you@example.com"
CONTACT_FROM_EMAIL="onboarding@resend.dev"